# Slack Bot Token (xoxb-...) — Slack app > OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-...

# Slack App-Level Token (xapp-...) — Slack app > Basic Information > App-Level Tokens
# Socket Mode için "connections:write" scope'u ile üretilir.
SLACK_APP_TOKEN=xapp-...

# İzlenecek kanal ID'si. Birden fazla için virgülle ayır: C0AAA,C0BBB,C0CCC
# Kanal adına sağ tık > "View channel details" en altta ID yazar.
QA_CHANNEL_ID=...

# --- Claude Code (motor) ---
# API anahtarı GEREKMEZ; bot yerel `claude` CLI'ı Max aboneliğinle kullanır.
# `claude setup-token` ile (Max hesabınla) üretilen uzun ömürlü token'ı buraya yapıştır.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat...

# launchd altında PATH minimaldir; gerekirse `which claude` tam yolunu yaz:
CLAUDE_BIN=claude

# ------------------------------------------------------------------------
# Tüm modellerde sürüm-bağımsız tag kullanılır; yeni sürüm çıkınca güncelleme
# gerekmez. (İstersen tam ID de yazabilirsin, örn. claude-opus-4-8.)

# --- Version Check ---
CLAUDE_HAIKU_MODEL=haiku
VERSION_CHECK_TIMEOUT=60
# Reasoning seviyesi (low|medium|high|xhigh|max).
VERSION_CHECK_EFFORT=low

# --- Bug Details ---
CLAUDE_OPUS_MODEL=opus
BUG_DETAILS_TIMEOUT=180
BUG_DETAILS_EFFORT=medium